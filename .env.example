# ─── SECOP Intelligence Hub — Variables de Entorno ──────────
# Copiar a .env y completar los valores

# ─── Database ─────────────────────────────────────────────
DB_PATH=./data/secop.db

# ─── SECOP Data Sources ───────────────────────────────────
# REQUERIDO: ID del dataset SECOP en Socrata (descubrir en Fase 0)
SECOP_DATASET_ID=
# Opcional: token para mejor rate limit en Socrata
SOCRATA_APP_TOKEN=

# ─── Auth ──────────────────────────────────────────────────
# REQUERIDO en produccion. Minimo 32 caracteres.
# Generar con: openssl rand -base64 32
AUTH_SECRET=

# ─── Azure OCR (Fase 2+) ──────────────────────────────────
AZURE_OCR_ENDPOINT=
AZURE_OCR_KEY=

# ─── LLM (Fase 2+) ────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── MercadoPago (Fase 2+) ────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ─── Notifications (Fase 1+) ─────────────────────────────
TELEGRAM_BOT_TOKEN=
RESEND_API_KEY=

# ─── LinkedIn (Fase 2+) ───────────────────────────────────
# NOTA: Las claves se almacenan cifradas en DB
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
