# ─── SECOP Intelligence Hub — Variables de Entorno ──────────
# Copiar a .env y completar los valores

# ─── Database ─────────────────────────────────────────────
DB_PATH=./data/secop.db

# ─── SECOP Data Sources ───────────────────────────────────
# REQUERIDO: ID del dataset SECOP en Socrata (p6dx-8zbt = Procesos de Contratacion)
SECOP_DATASET_ID=p6dx-8zbt
# Opcional: token para mejor rate limit en Socrata (50k req/h vs 1k req/h)
SOCRATA_APP_TOKEN=

# ─── Socrata Sync (Anti-Blocking) ────────────────────────
# Delay minimo entre requests API en ms. <50ms puede causar bloqueo.
SOCRATA_REQUEST_DELAY_MS=200
# Jitter aleatorio como fraccion del delay (0.25 = +/-25%)
SOCRATA_REQUEST_JITTER_PCT=0.25
# Maximo Retry-After en segundos antes de abortar
SOCRATA_MAX_RETRY_AFTER_SECONDS=300
# Tipo de sync: full o incremental
SOCRATA_SYNC_TYPE=incremental

# ─── Auth ──────────────────────────────────────────────────
# REQUERIDO en produccion. Minimo 32 caracteres.
# Generar con: openssl rand -base64 32
AUTH_SECRET=

# ─── SECOP Bot Credentials ────────────────────────────────
# REQUERIDO: Credenciales del bot para login automatizado en community.secop.gov.co
# Configurar via: secret-injector.ps1 set SECOP_BOT_USERNAME=...
SECOP_BOT_USERNAME=
SECOP_BOT_PASSWORD=

# ─── Captcha Solver (2captcha) ────────────────────────────
# REQUERIDO para login automatico a SECOP. Resuelve ReCaptcha v2 e imagen captcha.
# Obtener key en: https://2captcha.com
# Configurar via: secret-injector.ps1 set CAPTCHA_SOLVER_API_KEY=...
CAPTCHA_SOLVER_API_KEY=

# ─── Azure OCR (Fase 2+) ──────────────────────────────────
AZURE_OCR_ENDPOINT=
AZURE_OCR_KEY=

# ─── LLM (via OpenRouter) ─────────────────────────────────
# REEMPLAZO OpenAI/Anthropic. DeepSeek V4 Flash por defecto.
# Obtener key en: https://openrouter.ai/keys
OPENROUTER_API_KEY=
LLM_MODEL=deepseek/deepseek-v4-flash

# ─── MercadoPago (Fase 2+) ────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ─── Notifications (Fase 1+) ─────────────────────────────
TELEGRAM_BOT_TOKEN=
RESEND_API_KEY=

# ─── LinkedIn (Fase 2+) ───────────────────────────────────
# NOTA: Las claves se almacenan cifradas en DB
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Cron / Scheduler ────────────────────────────────────
# Token para autenticar llamadas a /api/cron/* (via Authorization: Bearer)
# Generar con: openssl rand -base64 32
CRON_SECRET=

# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
