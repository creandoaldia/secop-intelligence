# ─────────────────────────────────────────────────────────────
# SECOP Intelligence Hub — Environment Variables
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# ─── Database ───────────────────────────────────────────────
DB_PATH=./data/secop.db

# ─── SECOP Data (Socrata) ───────────────────────────────────
SECOP_API_URL=https://www.datos.gov.co/resource
# Dataset ID for SECOP II data — find via datos.gov.co
SECOP_DATASET_ID=jbjy-vk9h
SOCRATA_APP_TOKEN=

# ─── Socrata Sync ───────────────────────────────────────────
SOCRATA_REQUEST_DELAY_MS=200
SOCRATA_REQUEST_JITTER_PCT=0.25
SOCRATA_MAX_RETRY_AFTER_SECONDS=300
SOCRATA_SYNC_TYPE=incremental

# ─── Azure OCR (Document Intelligence) ──────────────────────
AZURE_OCR_ENDPOINT=
AZURE_OCR_KEY=

# ─── OpenAI (GPT-4o-mini extraction) ────────────────────────
OPENAI_API_KEY=

# ─── Anthropic (Claude Haiku verification) ──────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_VERIFIER_MODEL=claude-3-haiku-20240307

# ─── Auth ───────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ─── MercadoPago ────────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ─── LinkedIn OAuth ─────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── Notifications ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
RESEND_API_KEY=

# ─── Scheduler ──────────────────────────────────────────────
SYNC_INTERVAL_HOURS=6
CRON_SECRET=

# ─── App ────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
